# Grid-X Worker Configuration
# Copy this to worker_config.env and fill in your values

# URL of the Grid-X backend server (required)
BACKEND_URL=http://localhost:8000

# Email address you registered with on the Grid-X platform (required)
# The worker registers itself under this account so you earn credits
WORKER_EMAIL=you@example.com

# Optional: override the auto-generated agent ID
# If not set, a unique ID is generated and saved to worker/.agent_id
# AGENT_ID=agent_my_machine

# How often to poll for new tasks (seconds, default: 10)
# POLL_INTERVAL=10

# Resource limits passed to the Docker sandbox per task
# WORKER_CPU_LIMIT=2.0
# WORKER_MEMORY_LIMIT=4g
